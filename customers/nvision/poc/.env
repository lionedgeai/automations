# PostgreSQL Configuration
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_password_change_me
POSTGRES_DB=n8n

# n8n Authentication
# Basic auth credentials for accessing n8n UI
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin_change_me

# n8n API Configuration
# Generate a secure API key for programmatic access
N8N_API_KEY=demo-api-key-nvision-2026

# n8n Host Configuration
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Timezone
TIMEZONE=America/New_York

# ── AI Provider Configuration ──
# Options: "anthropic", "openai", or "mock" (default)
# Set to "mock" or leave empty for template-based demo (no API costs)
AI_PROVIDER=mock

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (ChatGPT)
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Note: For production, set these to secure values
# Generate API key with: openssl rand -hex 32
